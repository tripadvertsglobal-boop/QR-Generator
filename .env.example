# ── Supabase ────────────────────────────────────────────────────────────────
# Public (browser + server, RLS-enforced). Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
# Server-only. NEVER prefix with NEXT_PUBLIC_. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ── Vercel KV / Upstash Redis ───────────────────────────────────────────────
# Auto-injected when a KV/Upstash store is linked in Vercel. If unset, the
# redirect engine falls back to Supabase (slower, but functional locally).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── App ─────────────────────────────────────────────────────────────────────
# Origin that serves /r/<slug> redirects (used to build tracking URLs).
NEXT_PUBLIC_REDIRECT_DOMAIN=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Signing secret for password-gate unlock cookies (M7). Generate 32+ random bytes.
LINK_UNLOCK_SECRET=

# ── Deferred to later milestones (left here as the full contract) ────────────
# QSTASH_TOKEN=                          # M4 ingestion queue
# STRIPE_SECRET_KEY=                     # M6 billing
# STRIPE_WEBHOOK_SECRET=                 # M6
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=    # M6
# SAFE_BROWSING_API_KEY=                 # M5 URL safety
